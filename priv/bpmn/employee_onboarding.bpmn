<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_1" name="Employee Onboarding" processRef="employee_onboarding"/>
  </bpmn:collaboration>
  <bpmn:process id="employee_onboarding" name="Employee Onboarding" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_HR" name="HR">
        <bpmn:flowNodeRef>Start_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreateRecord</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PGW_Fork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>PGW_Join</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IGW_RoleFork</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetupDev</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SetupCRM</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_GeneralSetup</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>IGW_RoleJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_WelcomePackage</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_IT" name="IT">
        <bpmn:flowNodeRef>Sub_ITProvisioning</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Error_Boundary_IT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EscalateIT</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_ManualSetup</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Manager" name="Manager">
        <bpmn:flowNodeRef>Task_AssignMentor</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CreatePlan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_FirstWeekCheckin</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <!-- Start -->
    <bpmn:startEvent id="Start_1" name="New Employee">
      <bpmn:outgoing>Flow_ToCreateRecord</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- HR: Create Employee Record -->
    <bpmn:serviceTask id="Task_CreateRecord" name="Create Employee Record">
      <bpmn:incoming>Flow_ToCreateRecord</bpmn:incoming>
      <bpmn:outgoing>Flow_ToParallelFork</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Fork -->
    <bpmn:parallelGateway id="PGW_Fork" name="Parallel Fork">
      <bpmn:incoming>Flow_ToParallelFork</bpmn:incoming>
      <bpmn:outgoing>Flow_ToITSub</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToAssignMentor</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- IT Provisioning Sub-process -->
    <bpmn:subProcess id="Sub_ITProvisioning" name="IT Provisioning">
      <bpmn:incoming>Flow_ToITSub</bpmn:incoming>
      <bpmn:outgoing>Flow_ITToJoin</bpmn:outgoing>
      <bpmn:startEvent id="Sub_IT_Start" name="Sub Start">
        <bpmn:outgoing>SF_ToEmail</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Task_ProvisionEmail" name="Provision Email">
        <bpmn:incoming>SF_ToEmail</bpmn:incoming>
        <bpmn:outgoing>SF_ToVPN</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_SetupVPN" name="Setup VPN">
        <bpmn:incoming>SF_ToVPN</bpmn:incoming>
        <bpmn:outgoing>SF_ToEquipment</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Task_PrepareEquipment" name="Prepare Equipment">
        <bpmn:incoming>SF_ToEquipment</bpmn:incoming>
        <bpmn:outgoing>SF_ToSubEnd</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="Sub_IT_End" name="Sub End">
        <bpmn:incoming>SF_ToSubEnd</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="SF_ToEmail" sourceRef="Sub_IT_Start" targetRef="Task_ProvisionEmail"/>
      <bpmn:sequenceFlow id="SF_ToVPN" sourceRef="Task_ProvisionEmail" targetRef="Task_SetupVPN"/>
      <bpmn:sequenceFlow id="SF_ToEquipment" sourceRef="Task_SetupVPN" targetRef="Task_PrepareEquipment"/>
      <bpmn:sequenceFlow id="SF_ToSubEnd" sourceRef="Task_PrepareEquipment" targetRef="Sub_IT_End"/>
    </bpmn:subProcess>

    <!-- Error Boundary on IT Sub-process -->
    <bpmn:boundaryEvent id="Error_Boundary_IT" name="IT Error" attachedToRef="Sub_ITProvisioning">
      <bpmn:outgoing>Flow_ToEscalate</bpmn:outgoing>
      <bpmn:errorEventDefinition/>
    </bpmn:boundaryEvent>

    <!-- Error path: Escalate IT Issue -->
    <bpmn:serviceTask id="Task_EscalateIT" name="Escalate IT Issue">
      <bpmn:incoming>Flow_ToEscalate</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEndManual</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="End_ManualSetup" name="Manual Setup Required">
      <bpmn:incoming>Flow_ToEndManual</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Manager Track: Assign Mentor (User Task) -->
    <bpmn:userTask id="Task_AssignMentor" name="Assign Mentor">
      <bpmn:incoming>Flow_ToAssignMentor</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCreatePlan</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Manager Track: Create Training Plan -->
    <bpmn:serviceTask id="Task_CreatePlan" name="Create Training Plan">
      <bpmn:incoming>Flow_ToCreatePlan</bpmn:incoming>
      <bpmn:outgoing>Flow_ManagerToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Parallel Join -->
    <bpmn:parallelGateway id="PGW_Join" name="Parallel Join">
      <bpmn:incoming>Flow_ITToJoin</bpmn:incoming>
      <bpmn:incoming>Flow_ManagerToJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ToInclusiveFork</bpmn:outgoing>
    </bpmn:parallelGateway>

    <!-- Inclusive Fork (by role) -->
    <bpmn:inclusiveGateway id="IGW_RoleFork" name="Role Setup" default="Flow_ToGeneralSetup">
      <bpmn:incoming>Flow_ToInclusiveFork</bpmn:incoming>
      <bpmn:outgoing>Flow_ToSetupDev</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToSetupCRM</bpmn:outgoing>
      <bpmn:outgoing>Flow_ToGeneralSetup</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <bpmn:serviceTask id="Task_SetupDev" name="Setup Dev Environment">
      <bpmn:incoming>Flow_ToSetupDev</bpmn:incoming>
      <bpmn:outgoing>Flow_DevToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_SetupCRM" name="Setup CRM Access">
      <bpmn:incoming>Flow_ToSetupCRM</bpmn:incoming>
      <bpmn:outgoing>Flow_CRMToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_GeneralSetup" name="General Workspace Setup">
      <bpmn:incoming>Flow_ToGeneralSetup</bpmn:incoming>
      <bpmn:outgoing>Flow_GeneralToJoin</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Inclusive Join -->
    <bpmn:inclusiveGateway id="IGW_RoleJoin" name="Role Join">
      <bpmn:incoming>Flow_DevToJoin</bpmn:incoming>
      <bpmn:incoming>Flow_CRMToJoin</bpmn:incoming>
      <bpmn:incoming>Flow_GeneralToJoin</bpmn:incoming>
      <bpmn:outgoing>Flow_ToWelcome</bpmn:outgoing>
    </bpmn:inclusiveGateway>

    <!-- HR: Send Welcome Package -->
    <bpmn:serviceTask id="Task_WelcomePackage" name="Send Welcome Package">
      <bpmn:incoming>Flow_ToWelcome</bpmn:incoming>
      <bpmn:outgoing>Flow_ToCheckin</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- Manager: First Week Check-in (User Task) -->
    <bpmn:userTask id="Task_FirstWeekCheckin" name="First Week Check-in">
      <bpmn:incoming>Flow_ToCheckin</bpmn:incoming>
      <bpmn:outgoing>Flow_ToEnd</bpmn:outgoing>
    </bpmn:userTask>

    <!-- End -->
    <bpmn:endEvent id="End_1" name="Onboarding Complete">
      <bpmn:incoming>Flow_ToEnd</bpmn:incoming>
    </bpmn:endEvent>

    <!-- Sequence Flows -->
    <bpmn:sequenceFlow id="Flow_ToCreateRecord" sourceRef="Start_1" targetRef="Task_CreateRecord"/>
    <bpmn:sequenceFlow id="Flow_ToParallelFork" sourceRef="Task_CreateRecord" targetRef="PGW_Fork"/>
    <bpmn:sequenceFlow id="Flow_ToITSub" sourceRef="PGW_Fork" targetRef="Sub_ITProvisioning"/>
    <bpmn:sequenceFlow id="Flow_ToAssignMentor" sourceRef="PGW_Fork" targetRef="Task_AssignMentor"/>
    <bpmn:sequenceFlow id="Flow_ITToJoin" sourceRef="Sub_ITProvisioning" targetRef="PGW_Join"/>
    <bpmn:sequenceFlow id="Flow_ToCreatePlan" sourceRef="Task_AssignMentor" targetRef="Task_CreatePlan"/>
    <bpmn:sequenceFlow id="Flow_ManagerToJoin" sourceRef="Task_CreatePlan" targetRef="PGW_Join"/>
    <bpmn:sequenceFlow id="Flow_ToEscalate" sourceRef="Error_Boundary_IT" targetRef="Task_EscalateIT"/>
    <bpmn:sequenceFlow id="Flow_ToEndManual" sourceRef="Task_EscalateIT" targetRef="End_ManualSetup"/>
    <bpmn:sequenceFlow id="Flow_ToInclusiveFork" sourceRef="PGW_Join" targetRef="IGW_RoleFork"/>
    <bpmn:sequenceFlow id="Flow_ToSetupDev" sourceRef="IGW_RoleFork" targetRef="Task_SetupDev">
      <bpmn:conditionExpression>data["role"] == "engineering"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToSetupCRM" sourceRef="IGW_RoleFork" targetRef="Task_SetupCRM">
      <bpmn:conditionExpression>data["role"] == "sales"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_ToGeneralSetup" sourceRef="IGW_RoleFork" targetRef="Task_GeneralSetup"/>
    <bpmn:sequenceFlow id="Flow_DevToJoin" sourceRef="Task_SetupDev" targetRef="IGW_RoleJoin"/>
    <bpmn:sequenceFlow id="Flow_CRMToJoin" sourceRef="Task_SetupCRM" targetRef="IGW_RoleJoin"/>
    <bpmn:sequenceFlow id="Flow_GeneralToJoin" sourceRef="Task_GeneralSetup" targetRef="IGW_RoleJoin"/>
    <bpmn:sequenceFlow id="Flow_ToWelcome" sourceRef="IGW_RoleJoin" targetRef="Task_WelcomePackage"/>
    <bpmn:sequenceFlow id="Flow_ToCheckin" sourceRef="Task_WelcomePackage" targetRef="Task_FirstWeekCheckin"/>
    <bpmn:sequenceFlow id="Flow_ToEnd" sourceRef="Task_FirstWeekCheckin" targetRef="End_1"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
      <!-- Participant (pool) -->
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="120" y="0" width="1620" height="710"/>
      </bpmndi:BPMNShape>
      <!-- Lanes -->
      <bpmndi:BPMNShape id="Lane_HR_di" bpmnElement="Lane_HR" isHorizontal="true">
        <dc:Bounds x="150" y="0" width="1590" height="290"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_IT_di" bpmnElement="Lane_IT" isHorizontal="true">
        <dc:Bounds x="150" y="290" width="1590" height="250"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Manager_di" bpmnElement="Lane_Manager" isHorizontal="true">
        <dc:Bounds x="150" y="540" width="1590" height="170"/>
      </bpmndi:BPMNShape>
      <!-- HR Lane elements -->
      <bpmndi:BPMNShape id="Start_1_di" bpmnElement="Start_1">
        <dc:Bounds x="202" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="183" y="155" width="74" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateRecord_di" bpmnElement="Task_CreateRecord">
        <dc:Bounds x="290" y="90" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PGW_Fork_di" bpmnElement="PGW_Fork">
        <dc:Bounds x="445" y="105" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="PGW_Join_di" bpmnElement="PGW_Join">
        <dc:Bounds x="1005" y="105" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IGW_RoleFork_di" bpmnElement="IGW_RoleFork">
        <dc:Bounds x="1105" y="105" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupDev_di" bpmnElement="Task_SetupDev">
        <dc:Bounds x="1200" y="20" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupCRM_di" bpmnElement="Task_SetupCRM">
        <dc:Bounds x="1200" y="110" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_GeneralSetup_di" bpmnElement="Task_GeneralSetup">
        <dc:Bounds x="1200" y="200" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="IGW_RoleJoin_di" bpmnElement="IGW_RoleJoin">
        <dc:Bounds x="1355" y="105" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_WelcomePackage_di" bpmnElement="Task_WelcomePackage">
        <dc:Bounds x="1450" y="90" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_1_di" bpmnElement="End_1">
        <dc:Bounds x="1622" y="112" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1590" y="155" width="100" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- IT Lane elements -->
      <bpmndi:BPMNShape id="Sub_ITProvisioning_di" bpmnElement="Sub_ITProvisioning" isExpanded="true">
        <dc:Bounds x="500" y="310" width="450" height="130"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sub_IT_Start_di" bpmnElement="Sub_IT_Start">
        <dc:Bounds x="520" y="357" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProvisionEmail_di" bpmnElement="Task_ProvisionEmail">
        <dc:Bounds x="580" y="335" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetupVPN_di" bpmnElement="Task_SetupVPN">
        <dc:Bounds x="700" y="335" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareEquipment_di" bpmnElement="Task_PrepareEquipment">
        <dc:Bounds x="820" y="335" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Sub_IT_End_di" bpmnElement="Sub_IT_End">
        <dc:Bounds x="932" y="357" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Error_Boundary_IT_di" bpmnElement="Error_Boundary_IT">
        <dc:Bounds x="682" y="422" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_EscalateIT_di" bpmnElement="Task_EscalateIT">
        <dc:Bounds x="650" y="470" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_ManualSetup_di" bpmnElement="End_ManualSetup">
        <dc:Bounds x="802" y="492" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="775" y="535" width="90" height="14"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- Manager Lane elements -->
      <bpmndi:BPMNShape id="Task_AssignMentor_di" bpmnElement="Task_AssignMentor">
        <dc:Bounds x="500" y="585" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreatePlan_di" bpmnElement="Task_CreatePlan">
        <dc:Bounds x="660" y="585" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FirstWeekCheckin_di" bpmnElement="Task_FirstWeekCheckin">
        <dc:Bounds x="1450" y="585" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <!-- Sequence Flow edges -->
      <bpmndi:BPMNEdge id="Flow_ToCreateRecord_di" bpmnElement="Flow_ToCreateRecord">
        <di:waypoint x="238" y="130"/>
        <di:waypoint x="290" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToParallelFork_di" bpmnElement="Flow_ToParallelFork">
        <di:waypoint x="390" y="130"/>
        <di:waypoint x="445" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToITSub_di" bpmnElement="Flow_ToITSub">
        <di:waypoint x="470" y="155"/>
        <di:waypoint x="470" y="375"/>
        <di:waypoint x="500" y="375"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToAssignMentor_di" bpmnElement="Flow_ToAssignMentor">
        <di:waypoint x="470" y="155"/>
        <di:waypoint x="470" y="625"/>
        <di:waypoint x="500" y="625"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ITToJoin_di" bpmnElement="Flow_ITToJoin">
        <di:waypoint x="950" y="375"/>
        <di:waypoint x="1030" y="375"/>
        <di:waypoint x="1030" y="155"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCreatePlan_di" bpmnElement="Flow_ToCreatePlan">
        <di:waypoint x="600" y="625"/>
        <di:waypoint x="660" y="625"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ManagerToJoin_di" bpmnElement="Flow_ManagerToJoin">
        <di:waypoint x="760" y="625"/>
        <di:waypoint x="1030" y="625"/>
        <di:waypoint x="1030" y="155"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEscalate_di" bpmnElement="Flow_ToEscalate">
        <di:waypoint x="700" y="458"/>
        <di:waypoint x="700" y="470"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEndManual_di" bpmnElement="Flow_ToEndManual">
        <di:waypoint x="750" y="510"/>
        <di:waypoint x="802" y="510"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToInclusiveFork_di" bpmnElement="Flow_ToInclusiveFork">
        <di:waypoint x="1055" y="130"/>
        <di:waypoint x="1105" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToSetupDev_di" bpmnElement="Flow_ToSetupDev">
        <di:waypoint x="1130" y="105"/>
        <di:waypoint x="1130" y="60"/>
        <di:waypoint x="1200" y="60"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToSetupCRM_di" bpmnElement="Flow_ToSetupCRM">
        <di:waypoint x="1155" y="130"/>
        <di:waypoint x="1200" y="150"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToGeneralSetup_di" bpmnElement="Flow_ToGeneralSetup">
        <di:waypoint x="1130" y="155"/>
        <di:waypoint x="1130" y="240"/>
        <di:waypoint x="1200" y="240"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_DevToJoin_di" bpmnElement="Flow_DevToJoin">
        <di:waypoint x="1300" y="60"/>
        <di:waypoint x="1380" y="60"/>
        <di:waypoint x="1380" y="105"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_CRMToJoin_di" bpmnElement="Flow_CRMToJoin">
        <di:waypoint x="1300" y="150"/>
        <di:waypoint x="1355" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_GeneralToJoin_di" bpmnElement="Flow_GeneralToJoin">
        <di:waypoint x="1300" y="240"/>
        <di:waypoint x="1380" y="240"/>
        <di:waypoint x="1380" y="155"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToWelcome_di" bpmnElement="Flow_ToWelcome">
        <di:waypoint x="1405" y="130"/>
        <di:waypoint x="1450" y="130"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToCheckin_di" bpmnElement="Flow_ToCheckin">
        <di:waypoint x="1500" y="170"/>
        <di:waypoint x="1500" y="585"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ToEnd_di" bpmnElement="Flow_ToEnd">
        <di:waypoint x="1550" y="625"/>
        <di:waypoint x="1640" y="625"/>
        <di:waypoint x="1640" y="148"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
